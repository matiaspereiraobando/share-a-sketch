# Neon Postgres connection string
# Get this from https://neon.tech (or any Postgres provider).
# Use the pooled connection string for serverless deployments.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Admin panel
# Required for any environment that exposes the /admin routes.
# Set ADMIN_PASSWORD to a strong, unique value.
# Generate ADMIN_SESSION_SECRET with: openssl rand -base64 32
ADMIN_PASSWORD="change-me-in-production"
ADMIN_SESSION_SECRET="generate-a-32-byte-random-string"
